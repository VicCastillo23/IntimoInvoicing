{
  "name": "intimo-invoicing",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "description": "API de facturación (CFDI / Facturama) + SPA autoservicio — despliegue en EC2",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "gen:session-secret": "node -e \"console.log(require('crypto').randomBytes(48).toString('base64'))\"",
    "facturama:upload-csd": "node scripts/upload-csd-facturama.mjs",
    "smtp:ping": "node scripts/smtp-ping.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "nodemailer": "^6.10.1",
    "pg": "^8.13.1"
  }
}

# Copiar a .env y ajustar (nunca commitear .env)
NODE_ENV=development
PORT=3000

# URL pública para enlaces y QR en tickets (obligatoria para escribir PDF/XML en pos.purchase_orders y que Accounting los muestre en pólizas)
# Local: http://localhost:3000 | Producción (detrás de Nginx): https://facturacion.cafeintimo.mx
PUBLIC_BASE_URL=http://localhost:3000

# Facturama — sandbox
FACTURAMA_API_URL=https://apisandbox.facturama.mx
# Usuario y contraseña de tu cuenta API (en servidor: .env o Secrets Manager)
FACTURAMA_USER=tu_usuario_api
FACTURAMA_PASSWORD=tu_password_api

# CSD multiemisor (API Lite POST /api-lite/csds) — certificados de prueba SAT en sandbox
# Pegar cada valor en UNA sola línea (sin saltos de línea dentro del base64).
# NO subas .env al repositorio.
FACTURAMA_EMISOR_RFC=EKU9003173C9
FACTURAMA_CSD_CERTIFICATE_
FACTURAMA_CSD_PRIVATE_KEY_BASE64=MIIFDjBABgkqhkiG9w0BBQ0wMzAbBgkqhkiG9w0BBQwwDgQIAgEAAoIBAQACAggAMBQGCCqGSIb3DQMHBAgwggS8AgEAMASCBMh4EHl7aNSCaMDA1VlRoXCZ5UUmqErAbucRFLOMmsAaFNkyWR0dXIAh0CMjE6NpQIMZhQ0HH

# Emisor CFDI 4.0 (multiemisor, POST /api-lite/3/cfdis). Debe coincidir con el CSD cargado en Facturama.
# Si omites el nombre y el RFC es EKU9003173C9 (pruebas SAT), se usa un valor por defecto.
# FACTURAMA_EMISOR_NAME=ESCUELA KEMPER URGATE
# FACTURAMA_EMISOR_FISCAL_REGIME=601
# FACTURAMA_EXPEDITION_PLACE=42501
# FACTURAMA_CFDI_SERIE=INT
# Clave SAT y concepto (ej. factura cafetería productiva)
# FACTURAMA_PRODUCT_CODE=90101500
# FACTURAMA_CFDI_ITEM_DESCRIPTION=Consumo de alimentos
# FACTURAMA_CFDI_UNIT_LABEL=Unidad de servicio
# FACTURAMA_CFDI_UNIT_CODE=E48
# Forma de pago SAT: 28 = Tarjeta de débito (ajusta si cobras distinto)
# FACTURAMA_PAYMENT_FORM=28

# Correo (SMTP) — PDF+XML al receptor. Obligatorios: SMTP_HOST + SMTP_FROM (ver docs/ENV_SMTP_GMAIL.md)
#
# Gmail — cuenta de facturación Íntimo (rellena SMTP_PASS en tu .env local; nunca en Git)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=cafeintimo0@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# SMTP_FROM=cafeintimo0@gmail.com
# SMTP_FROM_NAME=Íntimo Café
# SMTP_MAIL_SUBJECT=Factura electrónica (CFDI) — Pedido
#
# Otro servidor (ej. dominio propio)
# SMTP_HOST=smtp.tudominio.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=facturacion@tudominio.com

# PostgreSQL — misma base que IntimoAccounting (esquema `pos`).
# Sin DATABASE_URL, las órdenes facturables siguen en modo mock.
# DATABASE_URL=postgresql://usuario:password@localhost:5432/intimo_accounting

# Producción (EC2 / AWS): exige timbrado real Facturama; sin credenciales válidas, POST /api/invoices/request → 503.
# INTIMO_REQUIRE_FACTURAMA_STAMP=1

# Opcional: carpeta para PDF/XML de cada CFDI (por defecto `data/cfdi-files/`).
# Ruta absoluta o relativa dentro de `data/`.
# INVOICE_CFDI_DIR=cfdi-files
